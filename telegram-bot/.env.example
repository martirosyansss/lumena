# ============================================================================
# MedBridge Tourism — Telegram bot configuration
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ============================================================================

# --- REQUIRED -------------------------------------------------------------
# Token from @BotFather (https://t.me/BotFather → /newbot)
BOT_TOKEN=123456:ABC-DEF_your_token_here

# --- LEADS DELIVERY -------------------------------------------------------
# Telegram chat that receives every lead (a manager group or your own chat).
# How to get it:
#   • Group:  add the bot to the group, send any message, then open
#             https://api.telegram.org/bot<BOT_TOKEN>/getUpdates and copy
#             "chat":{"id": -1001234567890 ...}  (group ids are negative).
#   • Personal: message the bot, open the same getUpdates URL, copy your id.
MANAGER_CHAT_ID=-1001234567890

# Google Sheet logging via Apps Script Web App (see google-apps-script/Code.gs).
# Leave empty to disable Sheets logging (local JSONL backup still works).
SHEETS_WEBAPP_URL=
# Must match the SECRET constant inside Code.gs (any random string).
SHEETS_SECRET=

# --- COORDINATOR CONTACTS (shown to clients) ------------------------------
# Public Telegram @username of the human coordinator (without the @).
COORDINATOR_USERNAME=
# WhatsApp number in international format, digits only (e.g. 79000000000).
COORDINATOR_WHATSAPP=
# Phone shown as tel: link (e.g. +7 900 000-00-00).
COORDINATOR_PHONE=

# --- CONTENT LINKS --------------------------------------------------------
# Lead-magnet guide (PDF/page URL). Leave empty to hide the guide button text.
GUIDE_URL=
# Public site URL.
SITE_URL=https://medbridge-tourism.com

# --- OPTIONAL -------------------------------------------------------------
# Default language before the user picks one: ru | en | hy
DEFAULT_LANG=ru
# Where local lead backups are appended (relative to project root).
LEADS_FILE=data/leads.jsonl
